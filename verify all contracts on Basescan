etherscan: {
  apiKey: {
    base: process.env.BASESCAN_API_KEY,
    baseSepolia: process.env.BASESCAN_API_KEY
  },
  customChains: [{
    network: "base",
    chainId: 8453,
    urls: {
      apiURL: "https://api.basescan.org/api",
