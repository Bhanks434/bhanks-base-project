const hre = require("hardhat");

async function main() {
  console.log("Deploying BhanksNFT...");
  const NFT = await hre.ethers.getContractFactory("BhanksNFT");
  const nft = await NFT.deploy();
  await nft.waitForDeployment();
  const address = await nft.getAddress();
  console.log("BhanksNFT deployed to:", address);
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});