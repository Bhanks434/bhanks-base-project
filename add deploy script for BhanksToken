const hre = require("hardhat");

async function main() {
  console.log("Deploying BhanksToken...");
  const Token = await hre.ethers.getContractFactory("BhanksToken");
  const token = await Token.deploy();
  await token.waitForDeployment();
  const address = await token.getAddress();
  console.log("BhanksToken deployed to:", address);
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});