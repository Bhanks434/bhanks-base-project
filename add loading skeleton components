export function Skeleton({ width = '100%', height = 20 }: { width?: string | number, height?: number }) {
  return (
    <div
      style={{
        width,
        height,
        background: 'var(--skeleton-bg, #e0e0e0)',
        borderRadius: 4,
        animation: 'pulse 1.5s ease-in-out infinite'
      }}
    />
  )
}

